---
import { SITE } from "../lib/site";
import { withBase } from "../lib/paths";
---

<a href={withBase("/")} class="logo" aria-label={`${SITE.title} — home`}>
  <svg
    class="logo-mark"
    viewBox="0 0 32 32"
    aria-hidden="true"
    focusable="false"
  >
    <rect width="32" height="32" rx="8" fill="var(--accent)"></rect>
    <path
      d="M8 22V10h3.2l3.6 7.2L18.4 10H21.6v12h-2.6v-7.4l-3 6h-1.4l-3-6V22H8Z"
      fill="white"></path>
  </svg>
  <span class="logo-text">{SITE.title}</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    font-size: var(--fs-md);
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .logo:hover {
    color: var(--text);
  }

  .logo-mark {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }
</style>
