---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths";
---

<BaseLayout title="Page not found" description="That page doesn't exist.">
  <div class="container not-found">
    <span class="tag">404</span>
    <h1>Page not found</h1>
    <p class="muted">
      The page you're looking for doesn't exist. It may have been moved or
      deleted.
    </p>
    <a class="btn" href={withBase("/")}>Back to home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding-block: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: center;
  }
</style>
