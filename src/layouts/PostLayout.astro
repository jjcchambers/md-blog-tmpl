---
import BaseLayout from "./BaseLayout.astro";
import { SITE } from "../lib/site";
import { formatDate, getAllPosts } from "../lib/posts";
import type { PostFrontmatter } from "../lib/posts";
import { withBase } from "../lib/paths";

interface Props {
  frontmatter: PostFrontmatter;
}
const { frontmatter } = Astro.props as Props;
const {
  title,
  description,
  date,
  author = SITE.author,
  tags = [],
  hero,
} = frontmatter;

// Find current/prev/next post for footer navigation.
const posts = getAllPosts();
const normalize = (s: string) => s.replace(/\/$/, "");
const here = normalize(Astro.url.pathname);
const idx = posts.findIndex((p) => normalize(withBase(p.url)) === here);
const prev = idx >= 0 ? posts[idx + 1] : undefined;
const next = idx > 0 ? posts[idx - 1] : undefined;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={hero ?? "/images/og-default.svg"}
>
  <article class="post container">
    <header class="post-header">
      {
        tags.length > 0 && (
          <div class="post-tags">
            {tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>
        )
      }
      <h1>{title}</h1>
      {description && <p class="post-lede">{description}</p>}
      <div class="post-byline">
        {author && <span>By {author}</span>}
        {date && (
          <>
            <span aria-hidden="true">·</span>
            <time datetime={date}>{formatDate(date)}</time>
          </>
        )}
      </div>
      {
        hero && (
          <div class="post-hero">
            <img src={withBase(hero)} alt="" />
          </div>
        )
      }
    </header>

    <div class="prose">
      <slot />
    </div>

    {
      (prev || next) && (
        <nav class="post-pager" aria-label="More posts">
          {prev ? (
            <a class="post-pager-item" href={withBase(prev.url)} rel="prev">
              <span class="muted">← Previous</span>
              <strong>{prev.frontmatter.title}</strong>
            </a>
          ) : (
            <span />
          )}
          {next && (
            <a
              class="post-pager-item align-right"
              href={withBase(next.url)}
              rel="next"
            >
              <span class="muted">Next →</span>
              <strong>{next.frontmatter.title}</strong>
            </a>
          )}
        </nav>
      )
    }
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .post-lede {
    font-size: var(--fs-lg);
    color: var(--text-muted);
    line-height: var(--lh-snug);
  }
  .post-byline {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--text-muted);
    font-size: var(--fs-sm);
  }
  .post-hero {
    margin-top: var(--space-4);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    aspect-ratio: 16 / 9;
    background: var(--surface-2);
  }
  .post-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .post-pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-top: var(--space-8);
    padding-top: var(--space-5);
    border-top: 1px solid var(--border);
  }
  .post-pager-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast);
  }
  .post-pager-item:hover {
    background: var(--surface-2);
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    color: var(--text);
  }
  .post-pager-item.align-right {
    text-align: right;
  }
  @media (max-width: 600px) {
    .post-pager {
      grid-template-columns: 1fr;
    }
    .post-pager-item.align-right {
      text-align: left;
    }
  }
</style>
